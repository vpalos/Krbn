{
  "name": "krbn",
  "version": "0.0.0",
  "description": "A web engine for non-photorealistic, pencil-style rendering of abstract and technical scenes.",
  "type": "module",
  "author": {
    "name": "Valeriu Paloș",
    "url": "https://github.com/vpalos"
  },
  "license": "MIT",
  "keywords": [
    "npr",
    "non-photorealistic",
    "sketch",
    "pencil",
    "hatching",
    "svg",
    "rendering",
    "hidden-line",
    "silhouette",
    "geometry"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./shapes": {
      "types": "./dist/shapes.d.ts",
      "import": "./dist/shapes.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "render": "bun run src/cli/render.ts",
    "render:gallery": "bun run src/cli/render.ts examples/gallery/*.krbn.ts",
    "render:animation": "bun run src/cli/render.ts examples/animation.krbn.ts",
    "render:importers": "bun run src/cli/render.ts examples/importers/stl.krbn.ts examples/importers/obj.krbn.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "typescript": "^5.5.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vpalos/Krbn.git"
  }
}
